{
  "id": "loader-dots",
  "name": "Loader Dots",
  "category": "loaders",
  "desc": "三点跳动加载动画",
  "html": "<div class=\"uiverse-dots\"><span></span><span></span><span></span></div>",
  "css": ".uiverse-dots{display:flex;gap:8px}.uiverse-dots span{width:10px;height:10px;border-radius:50%;background:#818cf8;animation:uiverse-bounce 1s infinite alternate}.uiverse-dots span:nth-child(2){animation-delay:.2s}.uiverse-dots span:nth-child(3){animation-delay:.4s}@keyframes uiverse-bounce{to{transform:translateY(-8px);opacity:.5}}"
}