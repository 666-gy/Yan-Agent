{
  "name": "yan-agent",
  "version": "1.3.2",
  "description": "Yan Agent — a modern, minimalist Agent desktop client built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "postinstall": "electron-rebuild -f -w node-pty || echo node-pty rebuild skipped",
    "rebuild:pty": "electron-rebuild -f -w node-pty",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.61.1"
  },
  "build": {
    "appId": "com.yan.agent",
    "productName": "Yan Agent",
    "icon": "renderer/assets/logo-light.ico",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "tokens.css",
      "lib/**/*",
      "renderer/**/*",
      "!lib/native/**/*.cs"
    ],
    "asarUnpack": [
      "lib/native/cursor-host/*.exe",
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "icon": "renderer/assets/logo-light.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "include": "build/installer.nsh",
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yan Agent",
      "artifactName": "Yan.Agent.Setup.${version}.${ext}"
    },
    "portable": {
      "artifactName": "Yan.Agent.Portable.${version}.${ext}"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^7.0.0",
    "node-pty": "^1.1.0"
  }
}
